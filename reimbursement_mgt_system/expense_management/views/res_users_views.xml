<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== EXTEND USER FORM ==================== -->
    <record id="res_users_view_form_expense" model="ir.ui.view">
        <field name="name">res.users.form.expense</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Expense Management" name="expense_management">
                    <group>
                        <group string="Role &amp; Company">
                            <field name="expense_company_id"/>
                            <field name="expense_role" widget="radio"/>
                        </group>
                        <group string="Reporting">
                            <field name="expense_manager_id"/>
                            <field name="is_manager_approver"/>
                        </group>
                    </group>

                    <separator string="Team Members"
                               invisible="expense_role not in ('manager', 'admin')"/>
                    <field name="team_member_ids"
                           invisible="expense_role not in ('manager', 'admin')">
                        <list>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="expense_role" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ==================== USER LIST FOR ADMIN ==================== -->
    <record id="action_expense_users" model="ir.actions.act_window">
        <field name="name">Users &amp; Roles</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('expense_company_id', '!=', False)]</field>
        <field name="context">{'default_expense_role': 'employee'}</field>
    </record>

</odoo>
