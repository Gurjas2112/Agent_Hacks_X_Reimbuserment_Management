<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Module Category -->
        <record id="module_category_expense_management" model="ir.module.category">
            <field name="name">Expense Management</field>
            <field name="description">Manage expense reimbursements with approval workflows</field>
            <field name="sequence">30</field>
        </record>

        <!-- Employee Group (base level) -->
        <record id="group_expense_employee" model="res.groups">
            <field name="name">Employee</field>
            <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
            <field name="comment">Can submit expenses and view own expense history.</field>
        </record>

        <!-- Manager Group (implies Employee) -->
        <record id="group_expense_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="implied_ids" eval="[Command.link(ref('group_expense_employee'))]"/>
            <field name="comment">Can approve/reject team expenses and view team expense history.</field>
        </record>

        <!-- Admin Group (implies Manager) -->
        <record id="group_expense_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="implied_ids" eval="[Command.link(ref('group_expense_manager'))]"/>
            <field name="comment">Full access: manage users, configure workflows, override approvals, view all expenses.</field>
        </record>

    </data>
</odoo>
